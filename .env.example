# roNavi Router — provider credentials
# Copy to `.env` and fill in the keys for the providers you want to route across.
# You only need at least ONE provider. Leave the rest blank and roNavi
# simply won't route to them.

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter (one key, hundreds of models incl. free tiers) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Ollama (local, free) — no key needed. Set the base URL only if it isn't the default.
# OLLAMA_BASE_URL=http://localhost:11434

# --- Optional overrides -------------------------------------------------------

# Classifier strategy: llm (default) | heuristic | hybrid | embedding.
# "hybrid"/"heuristic"/"embedding" avoid a per-request LLM call — cheaper & faster.
# RONAVI_CLASSIFIER=hybrid

# Embedding model for "embedding" mode (defaults to a local Ollama model).
# RONAVI_EMBEDDING_MODEL=ollama:nomic-embed-text

# Which model classifies each request in llm/hybrid mode (defaults to cheapest configured).
# RONAVI_CLASSIFIER_MODEL=anthropic:claude-haiku-4-5

# Daily spend cap in USD. When you approach it, roNavi downgrades to cheaper
# models; when you hit it, it either blocks or forces the cheapest model.
# RONAVI_BUDGET_USD=5

# Path to a JSON config file (see ronavi.config.example.json).
# RONAVI_CONFIG=./ronavi.config.json

# Proxy server port (default 8787).
# RONAVI_PORT=8787
